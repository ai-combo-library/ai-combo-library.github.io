  "evidenceLevels": {
    "description": "实测证据等级。等级越高，评分中 '功能声称' 字段权重越大。",
    "levels": {
      "L0": {
        "name": "仅文档 · 待验证",
        "weight": 1.0,
        "desc": "仅有 README/文档推断，还没有真实运行证据"
      },
      "L1": {
        "name": "可安装",
        "weight": 1.1,
        "desc": "能 pip/npm install 成功，有依赖文件"
      },
      "L2": {
        "name": "Smoke 通过 · 待闭环",
        "weight": 1.25,
        "desc": "安装或最小运行通过，等待组合闭环"
      },
      "L2-caveat": {
        "name": "Smoke 通过 · 有限制",
        "weight": 1.2,
        "desc": "单点样本或 smoke 跑通过，但存在明确配置、输出或样本限制"
      },
      "L3": {
        "name": "已实测可用",
        "weight": 1.4,
        "desc": "真实闭环跑通，有输入、执行和输出证据"
      },
      "L3-caveat": {
        "name": "实测通过 · 有限制",
        "weight": 1.32,
        "desc": "组合闭环跑通，但存在明确 caveat，需按适用条件使用"
      },
      "L4": {
        "name": "稳定复测",
        "weight": 1.55,
        "desc": "多样本、多环境、多次复测稳定；当前作为未来等级保留"
      }
    },
    "defaultLevel": "L0",
    "boostFields": [
      "功能声称"
    ]
  }
